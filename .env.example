# Azure AI Foundry
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://YOUR_PROJECT.api.azureml.ms
AZURE_FOUNDRY_MODEL_DEPLOYMENT=gpt-4.1-mini

# Azure AI Search (Foundry IQ backend)
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH.search.windows.net
AZURE_SEARCH_API_KEY=YOUR_KEY_HERE
FOUNDRY_IQ_KNOWLEDGE_BASE_NAME=compliance-iq-kb

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://YOUR_DI.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_KEY=YOUR_KEY_HERE

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://YOUR_OTEL_ENDPOINT
OTEL_SERVICE_NAME=complianceiq

# App Config
MOCK_MODE=true
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=10
